{
	"customTemplates": [
		{
			"name": "template-page-w-title",
			"title": "Page with Title"
		}
	],
	"settings": {
		"appearanceTools": true,
		"blocks": {
			"core/heading": {
				"color": {
					"background": false
				}
			}
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [
				{
					"colors": [
						"#000000",
						"#FFFFFF"
					],
					"name": "Duotone 1",
					"slug": "duotone-1"
				},
				{
					"colors": [
						"#000000",
						"#BBBBBB"
					],
					"name": "Duotone 2",
					"slug": "duotone-2"
				}
			],
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Color 1",
					"slug": "theme-1"
				},
				{
					"color": "#F7F7F7",
					"name": "Color 2",
					"slug": "theme-2"
				},
				{
					"color": "#d1d1d1",
					"name": "Color 3",
					"slug": "theme-3"
				},
				{
					"color": "#626262",
					"name": "Color 4",
					"slug": "theme-4"
				},
				{
					"color": "#111111",
					"name": "Color 5",
					"slug": "theme-5"
				}
			]
		},
		"custom": {
			"spacing-increment": "2.2",
			"spacing-unit": "10"
		},
		"layout": {
			"contentSize": "620px",
			"wideSize": "1440px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingScale": {
				"theme": {
					"steps": 1
				}
			},
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "30px",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(30px, 5vw, 50px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(30px, 7vw, 70px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(50px, 7vw, 90px)",
					"slug": "70"
				},
				{
					"name": "XX-Large",
					"size": "clamp(70px, 10vw, 140px)",
					"slug": "80"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "200",
							"src": [
								"file:./assets/fonts/manrope/manrope-200-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/manrope/manrope-300-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/manrope/manrope-400-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/manrope/manrope-500-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/manrope/manrope-600-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/manrope/manrope-700-normal.woff2"
							]
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "800",
							"src": [
								"file:./assets/fonts/manrope/manrope-800-normal.woff2"
							]
						}
					],
					"fontFamily": "Manrope, sans-serif",
					"name": "Manrope",
					"slug": "manrope"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Platypi",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/platypi/platypi-300-normal.woff2"
							]
						},
						{
							"fontFamily": "Platypi",
							"fontStyle": "italic",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/platypi/platypi-300-italic.woff2"
							]
						}
					],
					"fontFamily": "Platypi, serif",
					"name": "Platypi",
					"slug": "platypi"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "14px",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "20px",
						"min": "16px"
					},
					"name": "Medium",
					"size": "26px",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "26px",
						"min": "20px"
					},
					"name": "Large",
					"size": "24px",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "32px",
						"min": "22px"
					},
					"name": "Extra Large",
					"size": "40px",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "42px",
						"min": "38px"
					},
					"name": "2X Large",
					"size": "74px",
					"slug": "xx-large"
				}
			],
			"writingMode": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": "999px"
				},
				"variations": {
					"outline": {
						"border": {
							"width": "1px"
						},
						"spacing": {
							"padding": {
								"bottom": "13px",
								"left": "21px",
								"right": "21px",
								"top": "13px"
							}
						}
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "8px",
					"margin": {
						"top": "calc( var(--wp--style--block-gap) * 1.5)"
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": {
						"left": "var(--wp--preset--spacing--40)",
						"top": "var(--wp--preset--spacing--30)"
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-content": {
				"css": "& > div:first-child.alignfull { margin-top: calc( -1 * var(--wp--preset--spacing--20)) !important; } & > div:last-child.alignfull { margin-bottom: calc( -1 * var(--wp--preset--spacing--60)) !important; } & > p + div.alignfull { margin-top: var(--wp--style--block-gap) !important; }",
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--60)",
						"top": "var(--wp--preset--spacing--20)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.4"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--theme-4)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--theme-4)"
						}
					}
				},
				"typography": {
					"lineHeight": "1.4"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.3"
				}
			},
			"core/search": {
				"border": {
					"bottom": {
						"style": "none",
						"width": "0px"
					},
					"left": {
						"style": "none",
						"width": "0px"
					},
					"right": {
						"style": "none",
						"width": "0px"
					},
					"top": {
						"style": "none",
						"width": "0px"
					}
				}
			},
			"core/separator": {
				"border": {
					"top": {
						"width": "1px"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--theme-5)"
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "normal",
					"fontWeight": "500"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--theme-1)",
			"text": "var(--wp--preset--color--theme-5)"
		},
		"css": ".no-underline a { text-decoration: none; }",
		"elements": {
			"button": {
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--theme-5) 85%, #000)"
					}
				},
				"border": {
					"radius": "0"
				},
				"color": {
					"background": "var(--wp--preset--color--theme-5)",
					"text": "var(--wp--preset--color--theme-1)"
				},
				"spacing": {
					"padding": {
						"bottom": "16px",
						"left": "24px",
						"right": "24px",
						"top": "16px"
					}
				},
				"typography": {
					"fontFamily": {
						"ref": "styles.elements.heading.typography.fontFamily"
					},
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"caption": {
				"spacing": {
					"padding": {
						"top": "8px"
					}
				},
				"typography": {
					"fontSize": "14px",
					"fontWeight": "400"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": {
						"ref": "styles.elements.h1.typography.fontWeight"
					},
					"lineHeight": "1.1"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "normal",
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "500",
					"lineHeight": "1.3"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"letterSpacing": "0.1em",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"css": "&.has-background { padding: 0; }",
				"typography": {
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)",
			"padding": {
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)",
				"top": "0"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--manrope)",
			"fontSize": "16px",
			"fontStyle": "normal",
			"fontWeight": "300",
			"lineHeight": "1.6"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"version": 3,
	"$schema": "https://schemas.wp.org/trunk/theme.json"
}