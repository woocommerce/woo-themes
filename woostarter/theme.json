{
	"customTemplates": [
		{
			"name": "template-page-w-title",
			"title": "Page with Title"
		}
	],
	"settings": {
		"appearanceTools": true,
		"blocks": {
			"core/heading": {
				"color": {
					"background": false
				}
			}
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FFFFFF",
					"name": "Background",
					"slug": "theme-1"
				},
				{
					"color": "#F7F7F7",
					"name": "Tertiary",
					"slug": "theme-2"
				},
				{
					"color": "#686868",
					"name": "Secondary",
					"slug": "theme-3"
				},
				{
					"color": "rgba(17, 17, 17, 0.2)",
					"name": "Opacity 20%",
					"slug": "theme-4"
				},
				{
					"color": "#111111",
					"name": "Primary",
					"slug": "theme-5"
				}
			],
			"duotone": [
				{
					"colors": [
						"#000000",
						"#FFFFFF"
					],
					"name": "Duotone 1",
					"slug": "duotone-1"
				},
				{
					"colors": [
						"#000000",
						"#BBBBBB"
					],
					"name": "Duotone 2",
					"slug": "duotone-2"
				}
			]
		},
		"custom": {
			"spacing-increment": "2.2",
			"spacing-unit": "10"
		},
		"layout": {
			"contentSize": "645px",
			"wideSize": "1340px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingScale": {
                "steps": 1
            },
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "clamp(4px, 1vw, 10px)",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "clamp(10px, 2vw, 20px)",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "clamp(20px, 3vw, 30px)",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(30px, 5vw, 50px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(30px, 7vw, 70px)",
					"slug": "60"
				},
				{
					"name": "Extra Large",
					"size": "clamp(50px, 7vw, 90px)",
					"slug": "70"
				},
				{
					"name": "2X Large",
					"size": "clamp(70px, 10vw, 140px)",
					"slug": "80"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"name": "Manrope",
					"slug": "manrope",
					"fontFamily": "Manrope",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/manrope/Manrope-VariableFont_wght.woff2"
							],
							"fontWeight": "200 800",
							"fontStyle": "normal",
							"fontFamily": "Manrope"
						}
					]
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "13px",
						"min": "12px"
					},
					"name": "Small",
					"size": "13px",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "16px",
						"min": "14px"
					},
					"name": "Medium",
					"size": "16px",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "20px",
						"min": "18px"
					},
					"name": "Large",
					"size": "20px",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "26px",
						"min": "24px"
					},
					"name": "Extra Large",
					"size": "26px",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "34px",
						"min": "26px"
					},
					"name": "2X Large",
					"size": "34px",
					"slug": "xx-large"
				}
			],
			"writingMode": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": "999px"
				},
				"variations": {
					"outline": {
						"border": {
							"color": "currentColor",
							"width": "1px"
						},
						"css": ".wp-block-button__link:not(.has-background):hover {background-color:color-mix(in srgb, var(--wp--preset--color--contrast) 5%, transparent);}",
						"spacing": {
							"padding": {
								"bottom": "calc(1rem - 1px)",
								"left": "calc(2.25rem - 1px)",
								"right": "calc(2.25rem - 1px)",
								"top": "calc(1rem - 1px)"
							}
						}
					}
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "16px",
					"margin": {
						"top": "calc( var(--wp--style--block-gap) * 1.5)"
					}
				}
			},
			"core/columns": {
                "spacing": {
                    "blockGap": {
                        "left": "var(--wp--preset--spacing--40)",
                        "top": "var(--wp--preset--spacing--30)"
                    }
                }
            },
			"core/navigation": {
				"typography": {
                    "fontSize": "var(--wp--preset--font-size--medium)"
                },
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--30)"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"lineHeight": "1.4"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"lineHeight": "1.4",
					"letterSpacing": "1.4px",
					"textTransform": "uppercase"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.3"
				}
			},
			"core/search": {
				"border": {
					"bottom": {
						"style": "none",
						"width": "0px"
					},
					"left": {
						"style": "none",
						"width": "0px"
					},
					"right": {
						"style": "none",
						"width": "0px"
					},
					"top": {
						"style": "none",
						"width": "0px"
					}
				}
			},
			"core/separator": {
				"border": {
					"top": {
						"width": "1px"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--theme-5)"
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontStyle": "normal",
					"fontWeight": "700",
					"lineHeight": "1.3",
					"letterSpacing":"-0.2px"
				}
			},
			"core/query-pagination": {
				"typography": {
				"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"woocommerce/product-title": {
				"typography": {
					"fontSize":  "var(--wp--preset--font-size--large)"
				}
			},
			"woocommerce/product-price": {
				"typography": {
					"fontSize":  "var(--wp--preset--font-size--medium)",
					"lineHeight": "1"
				},
				"spacing": {
					"padding": {
					  "bottom": "var(--wp--preset--spacing--30)"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--theme-1)",
			"text": "var(--wp--preset--color--theme-5)"
		},
		"css": "",
		"elements": {
			"button": {
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--theme-5) 85%, #FFF)"
					}
				},
				"border": {
					"radius": "999px"
				},
				"color": {
					"background": "var(--wp--preset--color--theme-5)",
					"text": "var(--wp--preset--color--theme-1)"
				},
				"spacing": {
					"padding": {
						"bottom": "16px",
						"left": "24px",
						"right": "24px",
						"top": "16px"
					}
				},
				"typography": {
					"fontFamily": {
						"ref": "styles.elements.heading.typography.fontFamily"
					},
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"caption": {
				"spacing": {
					"padding": {
						"top": "8px"
					}
				},
				"typography": {
					"fontSize": "14px",
					"fontWeight": "400"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.1",
					"letterSpacing":"-0.68px"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.1",
					"letterSpacing":"-0.52px"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "normal",
					"lineHeight": "1.1",
					"letterSpacing":"-0.2px"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"lineHeight": "1.1",
					"letterSpacing":"-0.32px"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"lineHeight": "1.1",
					"letterSpacing":"-0.32px"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"lineHeight": "1.2",
					"letterSpacing":"1.3px",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"css": "&.has-background { padding: 0; }",
				"typography": {
					"fontStyle": "normal",
					"fontWeight": "500"
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)",
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--manrope)",
			"fontSize":  "var(--wp--preset--font-size--medium)",
			"fontStyle": "normal",
			"fontWeight": "400",
			"lineHeight": "1.4"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"version": 3,
	"$schema": "https://schemas.wp.org/trunk/theme.json"
}